# ──────────────────────────────────────────────────────────────────────────────
# SeoXpert — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
APP_ENV=development
ALLOW_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Supabase (self-hosted) ────────────────────────────────────────────────────
# Find these in your Supabase dashboard → Settings → API
SUPABASE_URL=http://host.docker.internal:8000
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# PostgreSQL direct connection (bypasses PostgREST, used by Go API)
# Use the pooler port (6543) for high-concurrency, direct port (5432) for migrations
DATABASE_URL=postgresql://postgres:your_db_password@host.docker.internal:5432/postgres?pool_max_conns=20

# ── Redis — Dedicated SeoXpert instance (NOT the shared kiit-redis) ───────────
# Docker container: seoxpert-redis exposed on host port 6380
# On the server:  REDIS_ADDR=localhost:6380
# Local dev (SSH tunnel -L 6380:localhost:6380): REDIS_ADDR=localhost:6380
REDIS_ADDR=localhost:6380
REDIS_PASSWORD=
REDIS_DB=0

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_ADDR=host.docker.internal:9000
CLICKHOUSE_DB=seoxpert
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Redpanda (Kafka-compatible) ───────────────────────────────────────────────
REDPANDA_BROKERS=host.docker.internal:9092

# ── Supabase Storage ──────────────────────────────────────────────────────────
STORAGE_BUCKET=seoxpert

# ── Next.js (frontend) ───────────────────────────────────────────────────────
# Public — safe to expose to browser
NEXT_PUBLIC_API_URL=http://localhost:8090
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
